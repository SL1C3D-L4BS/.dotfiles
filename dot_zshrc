# ─── Zellij floating pane launchers ("pills") ───────────────────────────────
# Opens a named tool as a floating pill inside the current Zellij session.
# Outside Zellij, runs the command directly.
_zj_float() {
  local cmd="$1" w="${2:-72%}" h="${3:-70%}" x="${4:-14%}" y="${5:-12%}"
  if [[ -n "$ZELLIJ" ]]; then
    zellij action new-pane \
      --floating \
      --width  "$w" \
      --height "$h" \
      --x      "$x" \
      --y      "$y" \
      -- zsh -ic "$cmd"
  else
    ${=cmd}
  fi
}

