# ─────────────────────────────────────────────────────────────────────────────
# Monitors — generated by chezmoi from monitors.conf.tmpl
# Machine-specific: set is_laptop = true in ~/.config/chezmoi/chezmoi.toml
# ─────────────────────────────────────────────────────────────────────────────

{{ if .machine.is_laptop -}}
# Laptop-only display
monitor = eDP-1, preferred, 0x0, 1.5

{{ else -}}
# Workstation: HDMI-A-1 left (portrait 270°), DP-3 right (landscape)
monitor = HDMI-A-1, 1920x1080@60, 0x0, 1, transform, 3
monitor = DP-3, 1920x1080@60, 1080x0, 1
{{ end -}}

# Fallback: any unspecified monitor gets preferred resolution
monitor = , preferred, auto, 1
