# ─────────────────────────────────────────────────────────────────────────────
# hypridle — generated by chezmoi (different timeouts for laptop vs desktop)
# ─────────────────────────────────────────────────────────────────────────────

general {
    lock_cmd = pidof hyprlock || hyprlock
    before_sleep_cmd = loginctl lock-session
    after_sleep_cmd = hyprctl dispatch dpms on
    ignore_dbus_inhibit = false
}

# Dim brightness before lock
listener {
    timeout = {{ if .machine.is_laptop }}120{{ else }}150{{ end }}
    on-timeout = brightnessctl -s set 8%
    on-resume = brightnessctl -r
}

# Lock
listener {
    timeout = {{ if .machine.is_laptop }}180{{ else }}300{{ end }}
    on-timeout = loginctl lock-session
}

# Screen off
listener {
    timeout = {{ if .machine.is_laptop }}210{{ else }}330{{ end }}
    on-timeout = hyprctl dispatch dpms off
    on-resume = hyprctl dispatch dpms on
}

# Suspend
listener {
    timeout = {{ if .machine.is_laptop }}900{{ else }}1800{{ end }}
    on-timeout = systemctl suspend
}
