            emphasis_0 255 85 85
            emphasis_1 255 121 198
            emphasis_2 144 144 144
            emphasis_3 45 45 45
        }
        multiplayer_user_colors {
            player_1 88 101 242
            player_2 224 224 224
            player_3 144 144 144
            player_4 45 45 45
            player_5 248 248 242
            player_6 26 26 26
            player_7 255 85 85
            player_8 40 42 54
