// ─────────────────────────────────────────────────────────────────────────────
// SL1C3D-L4BS default layout — single compact bar at bottom (clean, minimal chrome)
// ─────────────────────────────────────────────────────────────────────────────

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
    tab name="SL1C3D-L4BS" focus=true {
        pane
    }
}
