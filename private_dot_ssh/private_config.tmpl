# SSH config — SL1C3D-L4BS (managed by chezmoi, private_config.tmpl)
# Permissions: chmod 600 — auto-applied by chezmoi private_ prefix
# Keys live locally; only the config structure is chezmoi-managed.

# ─── GitHub ─────────────────────────────────────────────────────────────────
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    AddKeysToAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

