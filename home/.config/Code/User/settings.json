{
  "workbench.colorTheme": "SL1C3D-V1M",
  "workbench.iconTheme": "icons-carbon",
  "workbench.startupEditor": "none",
  "workbench.sideBar.location": "left",
  "workbench.activityBar.location": "default",
  "workbench.tree.indent": 16,

  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'JetBrains Mono', 'Fira Code', monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.6,
  "editor.letterSpacing": 0.3,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.wordWrap": "off",
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.scale": 1,
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.indentation": true,
  "editor.linkedEditing": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.scrollBeyondLastLine": false,
  "editor.stickyScroll.enabled": true,
  "editor.inlayHints.enabled": "on",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },

  "editor.tokenColorCustomizations": {
    "[SL1C3D-V1M]": {
      "comments": "#6B6B7B"
    }
  },

  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.defaultProfile.linux": "zsh",

  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/target": true,
    "**/.direnv": true,
    "**/bin/Debug": true,
    "**/obj": true
  },

  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": true,

  "search.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/.git": true,
    "**/*.lock": true,
    "**/.direnv": true,
    "**/bin/Debug": true
  },

  "window.titleBarStyle": "custom",
  "window.menuBarVisibility": "toggle",
  "window.commandCenter": true,

  "telemetry.telemetryLevel": "off",
  "update.mode": "manual",
  "extensions.autoUpdate": false,
  "security.workspace.trust.enabled": false,

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": { "source.fixAll": "explicit", "source.organizeImports.ruff": "explicit" }
  },
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "basic",
  "ruff.organizeImports": true,

  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.tabSize": 4
  },
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.cargo.allFeatures": true,
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.inlayHints.bindingModeHints.enable": true,
  "rust-analyzer.inlayHints.closureReturnTypeHints.enable": "always",

  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.codeActionsOnSave": { "source.organizeImports": "explicit" }
  },
  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "workspace",
  "go.formatTool": "goimports",
  "go.useLanguageServer": true,
  "gopls": { "ui.semanticTokens": true, "formatting.gofumpt": true },

  "[c]": { "editor.defaultFormatter": "ms-vscode.cpptools", "editor.tabSize": 4 },
  "[cpp]": { "editor.defaultFormatter": "ms-vscode.cpptools", "editor.tabSize": 4 },
  "C_Cpp.clang_format_fallbackStyle": "LLVM",
  "C_Cpp.intelliSenseEngine": "default",

  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": { "source.fixAll": "explicit", "source.organizeImports": "explicit" }
  },
  "omnisharp.useModernNet": true,
  "omnisharp.enableRoslynAnalyzers": true,
  "omnisharp.enableEditorConfigSupport": true,
  "dotnet.defaultSolution": "disable",

  "[zig]": { "editor.defaultFormatter": "ziglang.vscode-zig", "editor.tabSize": 4 },

  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[vue]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[svelte]": { "editor.defaultFormatter": "svelte.svelte-vscode", "editor.tabSize": 2 },
  "[astro]": { "editor.defaultFormatter": "astro-build.astro-vscode", "editor.tabSize": 2 },

  "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[scss]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[yaml]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[toml]": { "editor.defaultFormatter": "tamasfe.even-better-toml" },
  "[graphql]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.tabSize": 2 },
  "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.wordWrap": "on" },
  "[lua]": { "editor.tabSize": 2 },
  "[nix]": { "editor.tabSize": 2 },
  "[dockerfile]": { "editor.tabSize": 4 },
  "[terraform]": { "editor.defaultFormatter": "hashicorp.terraform", "editor.tabSize": 2 },
  "[sql]": { "editor.tabSize": 2 },
  "[shellscript]": { "editor.tabSize": 2 },

  "eslint.enable": true,
  "eslint.run": "onType",
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact", "vue", "svelte"],

  "tailwindCSS.emmetCompletions": true,
  "emmet.includeLanguages": { "javascript": "javascriptreact", "vue-html": "html" },

  "nix.enableLanguageServer": true,
  "nix.serverPath": "nil",
  "nix.serverSettings": { "nil": { "formatting": { "command": ["nixfmt"] } } },

  "docker.showStartPage": false,
  "terraform.languageServer.enable": true,

  "gitlens.codeLens.enabled": false,
  "gitlens.currentLine.enabled": true,
  "gitlens.hovers.enabled": true,

  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "errorLens.delay": 500,

  "todo-tree.general.tags": ["BUG", "HACK", "FIXME", "TODO", "XXX", "PERF", "NOTE"],

  "cSpell.userWords": ["nvim", "nvchad", "treesitter", "keymaps", "dotfiles", "chezmoi", "sl1c3d", "sliced"],

  "files.associations": {
    "*.shader": "shaderlab",
    "*.cginc": "hlsl",
    "*.compute": "hlsl",
    "*.hlsl": "hlsl",
    "*.asmdef": "json",
    "*.asmref": "json",
    "*.inputactions": "json"
  }
}
