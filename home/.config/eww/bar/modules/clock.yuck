; ── Clock module ───────────────────────────────────────────────
(defpoll clock_time
  :interval "5s"
  `date +'%-I:%M %p'`)

(defpoll clock_date
  :interval "60s"
  `date +'%a %d %b'`)

(defwidget clock-module []
  (eventbox
    :onclick "~/.config/eww/bar/popup-menus/scripts/toggle-cal.sh &"
    (box :class "clock-box" :orientation "h" :space-evenly false
      (label :class "pill-icon clock-i" :text " 󰅐 ")
      (label :class "pill-text" :text "${clock_date}  ${clock_time}"))))
