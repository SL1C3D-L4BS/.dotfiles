# ── Autostart ─────────────────────────────────────────────────
# exec runs once; exec_always runs on reload too

# Monitor layout (must run before picom/wallpaper)
exec_always --no-startup-id ~/.config/xrandr-setup.sh

# Compositor (transparency, shadows, blur)
exec_always --no-startup-id bash -c 'killall -q picom; sleep 0.3 && picom --config ~/.config/picom/picom.conf --daemon'

# eww bar (replaced polybar)
exec_always --no-startup-id bash -c 'sleep 0.4 && ~/.config/eww/launch.sh'

# Wallpaper — per-monitor
exec_always --no-startup-id bash -c 'sleep 0.6 && ~/.local/bin/wallpaper-set'

# Screen lock on suspend
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock -c 0D0D1A --nofork

# Notification daemon
exec --no-startup-id dunst

# AI panel daemon (Claude chat backend)
exec --no-startup-id ai-panel-daemon

# Clipboard manager
exec --no-startup-id greenclip daemon

# Input settings
exec --no-startup-id xset r rate 200 40
exec --no-startup-id numlockx on

# Fix java apps in i3
exec --no-startup-id wmname LG3D

# ── Workspace bootstrap (runs once on login) ─────────────────
# ws2: Brave browser
exec --no-startup-id i3-msg 'workspace number 2: 󰖟; exec brave'

# ws1: Dev terminal — tmux session
exec --no-startup-id bash -c 'sleep 1.5 && i3-msg "workspace number 1: " && alacritty --class dev_term,dev_term -e tmux new-session -s dev'
