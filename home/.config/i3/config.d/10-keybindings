# ── Keybindings ───────────────────────────────────────────────

# Terminal
bindsym $mod+Return exec alacritty
bindsym $mod+Shift+Return exec alacritty --class float_term,float_term

# Launcher (rofi)
bindsym $mod+d exec --no-startup-id rofi -show drun -show-icons
bindsym $mod+Tab exec --no-startup-id rofi -show window -show-icons
bindsym $mod+p exec --no-startup-id rofi -show run

# Fuzzy file browser
bindsym $mod+o exec --no-startup-id alacritty --class fzf_launcher,fzf_launcher -e ~/.local/bin/file-browser

# Editor
bindsym $mod+n exec alacritty -e nvim

# Kill window
bindsym $mod+Shift+q kill

# Focus — vim keys
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left  move left
bindsym $mod+Shift+Down  move down
bindsym $mod+Shift+Up    move up
bindsym $mod+Shift+Right move right

# Splits
bindsym $mod+backslash split h
bindsym $mod+minus split v

# Layouts
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle

# Float
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Scratchpads
bindsym $mod+F12 move scratchpad
bindsym $mod+F11 scratchpad show

# Named scratchpads
bindsym $mod+grave [class="float_term"] scratchpad show

# Focus parent/child
bindsym $mod+a focus parent
bindsym $mod+z focus child

# Volume (PulseAudio)

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute       exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute    exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle

# Brightness
bindsym XF86MonBrightnessUp   exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

# Screenshots
bindsym Print exec --no-startup-id maim ~/Pictures/shot_$(date +%Y%m%d_%H%M%S).png
bindsym Shift+Print exec --no-startup-id maim -s ~/Pictures/shot_$(date +%Y%m%d_%H%M%S).png
bindsym $mod+Shift+s exec --no-startup-id maim -s | xclip -selection clipboard -t image/png

# Lock screen
bindsym $mod+Shift+x exec --no-startup-id i3lock -c 1e1e2e

# Theme reload (matugen → reload all)
bindsym $mod+Shift+t exec --no-startup-id ~/.local/bin/theme-switch

# Reload / restart / exit
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'"

# Floating modifier
floating_modifier $mod
tiling_drag modifier titlebar

# Gap adjustment
bindsym $mod+equal       gaps inner current plus 5
bindsym $mod+Shift+equal gaps inner current minus 5
