# ── Appearance ────────────────────────────────────────────────
# Colors sourced from ~/.config/theme/palette — generated by matugen
# Falls back to sane defaults if palette not yet generated

# Harry Potter palette — Hogwarts midnight + house colors
set_from_resource $bg      background  #0D0D1A
set_from_resource $fg      foreground  #E8E6E3
set_from_resource $accent  color4      #2D6A4F
set_from_resource $urgent  color1      #C41E3A
set_from_resource $surface color0      #1A1A2E

# ── Spacing: 4px base grid ────────────────────────────────────
# bar: 24px height + 4px y-offset + 4px clearance = 32px top gap
# inner: 8px (2 × base), outer: 4px (1 × base)
gaps inner 8
gaps outer 4
gaps top 32
# smart_gaps disabled — must keep top gap for eww bar on all monitors
# (with smart_gaps on, single-container workspaces lose the 42px top gap,
#  causing windows to slide behind the bar on ws2/ws3)
smart_gaps off
smart_borders on

# Borders — pixel only, no titlebars (required for gaps)
for_window [class=".*"] border pixel 2
default_border pixel 2
default_floating_border pixel 2

# Window colors          border    background  text    indicator  child_border
client.focused           $accent   $bg         $fg     $accent    $accent
client.focused_inactive  $surface  $bg         $fg     $surface   $surface
client.unfocused         $surface  $bg         $fg     $surface   $surface
client.urgent            $urgent   $urgent     $bg     $urgent    $urgent
client.placeholder       $surface  $bg         $fg     $surface   $surface
client.background                  $bg
