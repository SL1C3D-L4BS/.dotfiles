#!/usr/bin/env python3
"""
ollama-list-models — list available local ollama models as JSON
Usage:
    ollama-list-models
    ollama-list-models | jq '.models[].name'
"""
import json, subprocess, sys

def main():
    try:
        result = subprocess.run(
            ["ollama", "list", "--format", "json"],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode == 0:
            data = json.loads(result.stdout or "[]")
            models = data if isinstance(data, list) else data.get("models", [])
        else:
            # Fallback: parse plain text output
            result2 = subprocess.run(["ollama", "list"], capture_output=True, text=True, timeout=5)
            lines = result2.stdout.strip().split("\n")[1:]  # skip header
            models = []
            for line in lines:
                parts = line.split()
                if parts:
                    models.append({"name": parts[0], "size": parts[2] if len(parts)>2 else "?", "modified": " ".join(parts[3:]) if len(parts)>3 else "?"})
    except Exception as e:
        models = []; error = str(e)
        print(json.dumps({"error": error, "models": []})); sys.exit(1)

    print(json.dumps({"model_count": len(models), "models": models}, indent=2))

if __name__ == "__main__":
    main()
