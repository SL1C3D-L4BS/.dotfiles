#!/usr/bin/env python3
"""
discover-dir — recursively map a directory: files, types, sizes, stats
Usage:
    discover-dir /path/to/dir
    discover-dir . --depth 3 --ext csv parquet json
"""
import os, json, argparse
from pathlib import Path
from collections import defaultdict

def main():
    p = argparse.ArgumentParser()
    p.add_argument("path", default=".", nargs="?")
    p.add_argument("--depth", type=int, default=5)
    p.add_argument("--ext", nargs="*", help="filter by extensions")
    p.add_argument("--min-size", type=int, default=0, help="min file size bytes")
    args = p.parse_args()

    root = Path(args.path).resolve()
    exts = set(f".{e.lstrip('.')}" for e in args.ext) if args.ext else None

    files = []
    ext_stats = defaultdict(lambda: {"count": 0, "total_bytes": 0})

    for dirpath, dirs, filenames in os.walk(root):
        depth = len(Path(dirpath).relative_to(root).parts)
        if depth > args.depth:
            dirs.clear(); continue
        # Skip hidden / venv / git dirs
        dirs[:] = [d for d in dirs if not d.startswith(".") and d not in ("node_modules","__pycache__",".venv","venv")]
        for fname in filenames:
            fp = Path(dirpath) / fname
            ext = fp.suffix.lower()
            if exts and ext not in exts: continue
            try:
                sz = fp.stat().st_size
                if sz < args.min_size: continue
                rel = str(fp.relative_to(root))
                files.append({"path": rel, "ext": ext, "size_bytes": sz})
                ext_stats[ext]["count"] += 1
                ext_stats[ext]["total_bytes"] += sz
            except OSError:
                pass

    output = {
        "root": str(root),
        "file_count": len(files),
        "extension_summary": {k: v for k, v in sorted(ext_stats.items(), key=lambda x: -x[1]["count"])},
        "files": sorted(files, key=lambda x: x["size_bytes"], reverse=True)[:200]
    }
    print(json.dumps(output, indent=2))

if __name__ == "__main__":
    main()
