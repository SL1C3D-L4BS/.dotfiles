  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6B6B7B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control", "keyword.operator.new", "keyword.operator.expression", "keyword.operator.logical", "keyword.operator.typeof"],
      "settings": {
        "foreground": "#9B59B6"
      }
    },
    {
      "name": "Keyword Return",
      "scope": ["keyword.control.return", "keyword.control.flow"],
      "settings": {
        "foreground": "#B97EDE"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#9B9BAB"
      }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#0077B6"
      }
    },
    {
      "name": "Function Parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": {
        "foreground": "#E8B930"
      }
    },
    {
      "name": "Built-in Functions",
      "scope": ["support.function.builtin", "support.function.magic"],
      "settings": {
        "foreground": "#4A90D9"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#2ECC71"
      }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#0097D9"
      }
    },
    {
      "name": "Numbers & Constants",
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other", "support.constant"],
      "settings": {
        "foreground": "#D4A017"
      }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#D4A017"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#C8C6C3"
      }
    },
    {
      "name": "Variable Built-in",
      "scope": ["variable.language", "variable.language.this", "variable.language.self", "variable.language.super"],
      "settings": {
        "foreground": "#C41E3A"
      }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property", "meta.object-literal.key"],
      "settings": {
        "foreground": "#1A8A6A"
      }
    },
    {
      "name": "Types & Classes",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": {
        "foreground": "#D4A017"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#0077B6"
      }
    },
    {
      "name": "Decorators & Annotations",
